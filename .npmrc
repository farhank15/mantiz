# Mantiz npm configuration
# Enforce exact versions for reproducible builds
save-exact=true

# Disable package-lock (we use package.json only)
package-lock=false

# Strict engine checks
engine-strict=true

# Prevent npm audit noise
audit=false

# Use the official npm registry
registry=https://registry.npmjs.org/

# Prefer offline cache for faster installs
prefer-offline=true
